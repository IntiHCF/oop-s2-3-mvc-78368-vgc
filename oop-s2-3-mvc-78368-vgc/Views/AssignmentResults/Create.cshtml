@model AssignmentResult

<h2>Add Assignment Result</h2>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Student</label>
        <select asp-for="StudentProfileId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Students, "Id", "Name"))">
        </select>
    </div>

    <div class="form-group">
        <label>Assignment</label>
        <select asp-for="AssignmentId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Assignments, "Id", "Title"))">
        </select>
    </div>

    <div class="form-group">
        <label>Score</label>
        <input asp-for="Score" class="form-control" />
    </div>

    <div class="form-group">
        <label>Feedback</label>
        <input asp-for="Feedback" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</form>