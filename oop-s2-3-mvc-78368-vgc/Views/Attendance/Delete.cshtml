@model AttendanceRecord

<h2>Delete Attendance</h2>

<h4>Are you sure you want to delete this record?</h4>

<div>
    <p><strong>Student:</strong> @Model.CourseEnrolment?.StudentProfile?.Name</p>
    <p><strong>Course:</strong> @Model.CourseEnrolment?.Course?.Name</p>
    <p><strong>Date:</strong> @Model.Date.ToShortDateString()</p>
    <p><strong>Week:</strong> @Model.WeekNumber</p>
    <p><strong>Present:</strong> @(Model.Present ? "Yes" : "No")</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>