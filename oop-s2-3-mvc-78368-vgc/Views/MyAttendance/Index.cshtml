@model IEnumerable<AttendanceRecord>

<h2>My Attendance</h2>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Date</th>
            <th>Present</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseEnrolment?.Course?.Name</td>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.Present</td>
            </tr>
        }
    </tbody>
</table>