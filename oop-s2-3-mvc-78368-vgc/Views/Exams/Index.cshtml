@model IEnumerable<Exam>

<h2>Exams</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Exam</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Course</th>
            <th>Date</th>
            <th>Max Score</th>
            <th>Results Released</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Course?.Name</td>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.MaxScore</td>
                <td>@item.ResultsReleased</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>