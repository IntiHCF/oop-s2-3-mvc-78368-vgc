@model ExamResult

<h2>Add Exam Result</h2>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Student</label>
        <select asp-for="StudentProfileId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Students, "Id", "Name"))">
        </select>
    </div>

    <div class="form-group">
        <label>Exam</label>
        <select asp-for="ExamId"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Exams, "Id", "Title"))">
        </select>
    </div>

    <div class="form-group">
        <label>Score</label>
        <input asp-for="Score" class="form-control" />
    </div>

    <div class="form-group">
        <label>Grade</label>
        <input asp-for="Grade" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</form>