@model IEnumerable<ExamResult>

<h2>Exam Results</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Add Result</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Student</th>
            <th>Exam</th>
            <th>Score</th>
            <th>Grade</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentProfile?.Name</td>
                <td>@item.Exam?.Title</td>
                <td>@item.Score</td>
                <td>@item.Grade</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>